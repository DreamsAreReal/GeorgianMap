# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ─── Database ─────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=georgia_places
DB_USER=georgia_places_app
# Generate: openssl rand -base64 32
DB_PASSWORD=__CHANGE_ME__

# ─── External APIs ─────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=__CHANGE_ME__
GEMINI_API_KEY=__CHANGE_ME__
MAPTILER_KEY=__CHANGE_ME__
CF_TURNSTILE_SECRET=__CHANGE_ME__
CF_TURNSTILE_SITEKEY=__CHANGE_ME__

# ─── Cloudflare R2 (backups) ───────────────────────────────────────────
R2_ACCESS_KEY_ID=__CHANGE_ME__
R2_SECRET_ACCESS_KEY=__CHANGE_ME__
R2_BUCKET=georgia-places-backups

# ─── Healthchecks.io UUIDs ─────────────────────────────────────────────
HEALTHCHECKS_PARSER_UUID=__CHANGE_ME__
HEALTHCHECKS_BACKUP_UUID=__CHANGE_ME__
HEALTHCHECKS_VERIFY_UUID=__CHANGE_ME__

# ─── ASP.NET Core ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
DOTNET_GCHeapHardLimit=200000000

# ─── Observability ─────────────────────────────────────────────────────
# Grafana Cloud OTLP HTTP endpoint (per ADR-0006)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# Auth header is mounted via Docker secret — see secrets/ section below.
# Do NOT put credentials directly in env vars (leak via `docker compose config`).
OTEL_SERVICE_NAME=georgia-places-api
OTEL_BSP_SCHEDULE_DELAY=30000
OTEL_METRIC_EXPORT_INTERVAL=60000

# ─── Docker secrets (paths inside container) ───────────────────────────
# These match secrets: section in docker-compose.yml.
OTEL_EXPORTER_OTLP_HEADERS_FILE=/run/secrets/otlp_headers
SENTRY_DSN_FILE=/run/secrets/sentry_dsn
